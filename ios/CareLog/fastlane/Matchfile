# CareLog iOS Matchfile
# Documentation: https://docs.fastlane.tools/actions/match/

# Git repository to store certificates and profiles
git_url(ENV["MATCH_GIT_URL"] || "git@github.com:subhajitsanyal/carelog-certificates.git")

# Default storage mode
storage_mode("git")

# App identifier(s)
app_identifier(["com.carelog.CareLog"])

# Apple ID
username(ENV["APPLE_ID"] || "your-apple-id@example.com")

# Team ID
team_id(ENV["TEAM_ID"] || "XXXXXXXXXX")

# Default type
type("appstore")

# Clone using SSH
git_basic_authorization(nil)

# Use shallow clone for faster operations
shallow_clone(true)

# Platform
platform("ios")

# Don't force create new profiles
force(false)

# Read only mode for CI (prevents accidental changes)
readonly(is_ci)

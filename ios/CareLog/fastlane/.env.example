# CareLog iOS Fastlane Environment Variables
# Copy this file to .env and fill in your values

# Apple Configuration
APPLE_ID=your-apple-id@example.com
TEAM_ID=XXXXXXXXXX
ITC_TEAM_ID=123456789

# Firebase Configuration
FIREBASE_TOKEN=your_firebase_ci_token_here
FIREBASE_IOS_APP_ID=1:000000000000:ios:0000000000000000000000

# Match Configuration (code signing)
MATCH_GIT_URL=git@github.com:your-org/carelog-certificates.git
MATCH_PASSWORD=your_match_password

# App Store Connect API (recommended for CI)
# APP_STORE_CONNECT_API_KEY_PATH=fastlane/AuthKey_XXXXXXXXXX.p8
# APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXXXXXXX
# APP_STORE_CONNECT_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# CI Configuration
CI_BUILD_NUMBER=

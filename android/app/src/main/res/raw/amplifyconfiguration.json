{
  "UserAgent": "aws-amplify-cli/2.0",
  "Version": "1.0",
  "auth": {
    "plugins": {
      "awsCognitoAuthPlugin": {
        "UserAgent": "aws-amplify-cli/0.1.0",
        "Version": "0.1.0",
        "IdentityManager": {
          "Default": {}
        },
        "CognitoUserPool": {
          "Default": {
            "PoolId": "ap-south-1_uiEZhWVXB",
            "AppClientId": "1kjdqj21bljak87e602d8r84f2",
            "Region": "ap-south-1"
          }
        },
        "Auth": {
          "Default": {
            "OAuth": {
              "WebDomain": "carelog-dev.auth.ap-south-1.amazoncognito.com",
              "AppClientId": "1kjdqj21bljak87e602d8r84f2",
              "SignInRedirectURI": "carelog://callback",
              "SignOutRedirectURI": "carelog://signout",
              "Scopes": [
                "email",
                "openid",
                "profile"
              ]
            },
            "authenticationFlowType": "USER_SRP_AUTH",
            "socialProviders": [],
            "usernameAttributes": [
              "EMAIL"
            ],
            "signupAttributes": [
              "EMAIL"
            ],
            "passwordProtectionSettings": {
              "passwordPolicyMinLength": 8,
              "passwordPolicyCharacters": [
                "REQUIRES_LOWERCASE",
                "REQUIRES_UPPERCASE",
                "REQUIRES_NUMBERS",
                "REQUIRES_SYMBOLS"
              ]
            },
            "mfaConfiguration": "OPTIONAL",
            "mfaTypes": [
              "TOTP"
            ],
            "verificationMechanisms": [
              "EMAIL"
            ]
          }
        }
      }
    }
  }
}
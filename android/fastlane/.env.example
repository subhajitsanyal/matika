# CareLog Android Fastlane Environment Variables
# Copy this file to .env and fill in your values

# Firebase Configuration
FIREBASE_TOKEN=your_firebase_ci_token_here
FIREBASE_ANDROID_APP_ID=1:000000000000:android:0000000000000000000000

# Signing Configuration
KEYSTORE_PATH=/path/to/carelog-release.keystore
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=carelog
KEY_PASSWORD=your_key_password

# Google Play Configuration
GOOGLE_PLAY_JSON_KEY=fastlane/google-play-key.json

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# CI Configuration
CI_BUILD_NUMBER=
